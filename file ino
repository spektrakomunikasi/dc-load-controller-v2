void readAllSensors() {
  int potValue = analogRead(POT_PIN);
  mosfetPWM = map(potValue, 0, 1023, 0, 255);

  int currentRaw = analogRead(CURRENT_SENSE_PIN);
  float senseVoltage = (currentRaw * REF_VOLTAGE) / ADC_RESOLUTION;
  measuredCurrent = senseVoltage / SHUNT_RESISTOR;
  
  if (measuredCurrent > MAX_CURRENT) measuredCurrent = MAX_CURRENT;
  if (measuredCurrent < 0.0) measuredCurrent = 0.0;

  int voltageRaw = analogRead(VOLTAGE_SENSE_PIN);
  float voltageADC = (voltageRaw * REF_VOLTAGE) / ADC_RESOLUTION;
  
  if (voltageADC > 5.0) voltageADC = 5.0;
  
  measuredVoltage = voltageADC * VOLTAGE_DIVIDER_RATIO;
  
  if (measuredVoltage > MAX_VOLTAGE + 2.0) measuredVoltage = MAX_VOLTAGE + 2.0;
  if (measuredVoltage < 0.0) measuredVoltage = 0.0;

  // ===== TEMPERATURE READ WITH VALIDATION =====
  sensors.requestTemperatures();
  float tempRead = sensors.getTempCByIndex(0);
  
  // PENTING: Validate temperature reading
  // Valid range: -55°C to +125°C untuk DS18B20
  // Jika di luar range atau 0.0 = sensor error
  if (tempRead > -55.0 && tempRead < 125.0 && tempRead != 85.0) {
    measuredTemp = tempRead;
  } else {
    // Jika tidak valid, gunakan 25.0C default (safe)
    // atau biarkan 0.0 untuk debug
    Serial.println("WARNING: Temperature sensor reading invalid!");
    Serial.print("Raw temp: ");
    Serial.println(tempRead);
  }
}

// ===== Add this function untuk test sensor =====
void testTemperatureSensor() {
  Serial.println("\n=== Temperature Sensor Test ===");
  Serial.print("Device count: ");
  Serial.println(sensors.getDeviceCount());
  
  if (sensors.getDeviceCount() == 0) {
    Serial.println("ERROR: No temperature sensor detected!");
    Serial.println("Check:");
    Serial.println("1. Yellow wire connected to D4");
    Serial.println("2. Black wire connected to GND");
    Serial.println("3. Red wire connected to +5V");
    Serial.println("4. 4.7k resistor from D4 to +5V (PULL-UP)");
  } else {
    Serial.println("OK: Temperature sensor detected!");
    
    // Read temperature
    sensors.requestTemperatures();
    float temp = sensors.getTempCByIndex(0);
    Serial.print("Temperature reading: ");
    Serial.print(temp);
    Serial.println("C");
  }
  Serial.println("============================\n");
}

